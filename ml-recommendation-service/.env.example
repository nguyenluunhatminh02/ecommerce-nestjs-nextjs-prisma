# CORS Origins (comma-separated or JSON array)
CORS_ORIGINS=https://your-app.vercel.app,https://your-backend.koyeb.app

# Database URL (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ML Model Storage Directory
ML_MODEL_DIR=/app/models

# Redis URL (Upstash, Redis Cloud, etc.)
REDIS_URL=rediss://:password@host:port/0

# Optional: API Key for authentication
# API_KEY=your-secret-api-key

# Optional: Port (default: 8000, override with PORT env var in cloud)
# PORT=8000
